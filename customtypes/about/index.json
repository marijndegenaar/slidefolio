          "multi": "paragraph,hyperlink"
        }
      },
      "featured_project": {
        "type": "Link",
        "config": {
          "label": "Featured Project",
          "select": "document",
          "customtypes": ["project"]
        }
      },
      "project_order": {
        "type": "Group",
        "config": {
          "label": "Project Order",
          "repeat": true,
          "fields": {
            "project": {
              "type": "Link",
              "config": {
                "label": "Project",
                "select": "document",
                "customtypes": ["project"]
              }
            }
          }
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {}
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        },
        "type": "Text"
      },
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_image": {
        "config": {
          "constraint": {
            "height": 1260,
            "width": 2400
          },
          "label": "Meta Image",
          "thumbnails": []
        },
        "type": "Image"
      }
    }
